shuffle_colors = function(starting_palette) {
out = character()
for (c in 1:(length(starting_palette)/2)) {
out = append(out, starting_palette[c])
out = append(out, starting_palette[length(cstarting_palette) - (c - 1)])
}
return(out)
}
pal = shuffle_colors(rainbow_cols)
shuffle_colors = function(starting_palette) {
out = character()
for (c in 1:(length(starting_palette)/2)) {
out = append(out, starting_palette[c])
out = append(out, starting_palette[length(starting_palette) - (c - 1)])
}
return(out)
}
